LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
MODEL_A=llama3.2:3b
MODEL_B=qwen2.5:3b
MODEL_JUDGE=llama3.2:3b

# Optional: only needed for OpenAI or OpenAI-compatible APIs such as Academic Cloud/SAIA.
OPENAI_API_KEY=your_api_key_here
OPENAI_BASE_URL=https://api.openai.com/v1

